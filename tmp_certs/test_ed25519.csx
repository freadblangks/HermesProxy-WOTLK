#r "nuget: BouncyCastle.Cryptography, 2.6.2"
using Org.BouncyCastle.Crypto.Parameters;
using Org.BouncyCastle.Crypto.Signers;

byte[] privateKey = { 0x08, 0xBD, 0xC7, 0xA3, 0xCC, 0xC3, 0x4F, 0x3F,
    0x6A, 0x0B, 0xFF, 0xCF, 0x31, 0xC1, 0xB6, 0x97,
    0x69, 0x1E, 0x72, 0x9A, 0x0A, 0xAB, 0x2C, 0x77,
    0xC3, 0x6F, 0x8A, 0xE7, 0x5A, 0x9A, 0xA7, 0xC9 };

var privParams = new Ed25519PrivateKeyParameters(privateKey, 0);
var pubParams = privParams.GeneratePublicKey();
byte[] pubBytes = pubParams.GetEncoded();
Console.WriteLine($"Derived public key: {BitConverter.ToString(pubBytes)}");

byte[] expected = { 0x02, 0x59, 0x6F, 0x0D, 0x0C, 0x06, 0x1A, 0x8B,
    0x30, 0x74, 0x59, 0x88, 0xFD, 0x72, 0xC5, 0x9E,
    0x29, 0xEC, 0x36, 0x7F, 0xB0, 0xF3, 0x41, 0xF2,
    0x8E, 0x0F, 0x08, 0xD0, 0x37, 0xBA, 0xFC, 0x69 };
Console.WriteLine($"Expected pub key:   {BitConverter.ToString(expected)}");
Console.WriteLine($"Keys match: {pubBytes.SequenceEqual(expected)}");
